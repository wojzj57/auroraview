{
  "name": "@auroraview/sdk",
  "version": "0.6.0",
  "description": "Framework-agnostic SDK for AuroraView WebView bridge",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:assets": "tsup --config tsup.assets.config.ts",
    "build:all": "npm run build && npm run build:assets",
    "dev": "tsup --watch",
    "dev:test": "npx serve tests/e2e/test-app -p 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.5",
    "serve": "^14.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "auroraview",
    "webview",
    "dcc",
    "ipc",
    "bridge",
    "tauri-like"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loonghao/auroraview.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
